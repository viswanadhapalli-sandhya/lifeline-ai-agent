# Python virtual environments (root and nested)
.venv/
venv/
env/

# -----------------------------
# Backend (Python)
# -----------------------------
backend/.env
backend/.env.*
!backend/.env.example

backend/.venv/
backend/venv/

backend/__pycache__/
backend/**/*.py[cod]
backend/**/*.pyo
backend/**/*.pyd
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.coverage
backend/htmlcov/

# Build/distribution artifacts
backend/build/
backend/dist/
backend/*.egg-info/

# Python/Jupyter checkpoints
backend/.ipynb_checkpoints/

# Sensitive backend keys
backend/app/serviceAccountKey.json
backend/app/core/serviceAccountKey.json
backend/**/serviceAccountKey.json

# -----------------------------
# Frontend (Vite / Node)
# -----------------------------
frontend/.env
frontend/.env.*
!frontend/.env.example

frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# JS package manager/debug logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# -----------------------------
# Generic Node (safety)
